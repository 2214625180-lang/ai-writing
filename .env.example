# PostgreSQL connection string used by Prisma in all environments.
DATABASE_URL="postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE_NAME?schema=public"

# Clerk public key exposed to the browser for client-side auth widgets and session handling.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key"

# Clerk server secret used by Next.js server code, middleware, and protected routes.
CLERK_SECRET_KEY="sk_test_your_clerk_secret_key"

# Clerk App Router sign-in route path used by auth redirects and middleware.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"

# Clerk App Router sign-up route path used by auth redirects and middleware.
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Clerk redirect target after sign-in in the Next.js App Router app.
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"

# Clerk redirect target after sign-up in the Next.js App Router app.
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# OpenAI API key used by server-side generation, streaming routes, and AI actions.
OPENAI_API_KEY="sk-your-openai-api-key"

# Stripe secret key used by server-side billing, checkout, and subscription management.
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"

# Stripe webhook signing secret used to verify incoming webhook events securely.
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# Stripe price ID for the individual Pro subscription plan.
STRIPE_PRO_PRICE_ID="price_your_pro_monthly_plan_id"

# Stripe price ID for the Team subscription plan.
STRIPE_TEAM_PRICE_ID="price_your_team_monthly_plan_id"

# Public application base URL used for redirects, webhooks, and absolute links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
